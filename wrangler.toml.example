name = "__WORKER_NAME__"
main = "src/index.js"
compatibility_date = "2025-11-02"

workers_dev = true
# 关闭遥测
send_metrics = false

[assets]
directory = "./public"
binding = "ASSETS"
# 需要让 Worker 先执行，以便统一鉴权和安全响应头
run_worker_first = true

# KV 命名空间
[[kv_namespaces]]
binding = "KV"  # 不要修改此项
id = "__KV_NAMESPACE_ID__"

[observability]
enabled = true
head_sampling_rate = 1

[vars]
JWT_SECRET = "__JWT_SECRET__"
DEBUG_SECRET = "__DEBUG_SECRET__"
INIT_SECRET = "__INIT_SECRET__"
LOG_LEVEL = "info"